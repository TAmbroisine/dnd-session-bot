# Token du bot (Discord Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=colle_ton_token_ici

# IDs Discord (clic droit > Copier l'identifiant, avec le mode développeur activé)
GUILD_ID=000000000000000000
CHANNEL_ID=000000000000000000
GM_USER_ID=000000000000000000
PLAYER_ROLE_ID=000000000000000000

# Chemin de la base SQLite (dans le volume Docker)
DB_PATH=/app/data/bot.db
